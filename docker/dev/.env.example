# Copy to .env and edit. Do not commit .env.

# Required: absolute path to the colony git repository on the host
PASEKA_REPO=/path/to/your/colony

# Required: host directory mounted as ~/.config/paseka inside the container.
# Prefer a dedicated server path (not your laptop home) so colony_root can be
# /home/dev/workspace — see docs/guide/homelab-deployment.md
PASEKA_HOME=/var/lib/paseka/config

# Cursor API key (https://cursor.com/settings) — required for adapter bees
CURSOR_API_KEY=

# NATS with JetStream (overrides nats.url in home config.yaml)
# Host NATS from Docker Desktop / Linux with extra_hosts:
PASEKA_NATS_URL=nats://host.docker.internal:4222
# Or a remote/homelab NATS:
# PASEKA_NATS_URL=nats://192.168.1.10:4222

# Optional host paths for Cursor state (defaults use $HOME on the compose host)
# CURSOR_HOME=/home/you/.cursor
# CURSOR_CONFIG=/home/you/.config/cursor

# Published Queen Console port on the host
PASEKA_CONSOLE_PORT=8787

# Match the host user that owns the bind mounts (avoid root-owned files)
DEV_UID=1000
DEV_GID=1000
